{
  "exportedMediaSourceDataList": {
    "mediaSources": [
      {
        "factoryId": "web-selector",
        "version": 2,
        "arguments": {
          "name": "测试源",
          "description": "Local fixture source",
          "searchConfig": {
            "searchUrl": "/fixtures/sample-search.html?wd={keyword}",
            "searchUseOnlyFirstWord": false,
            "searchRemoveSpecial": true,
            "subjectFormatId": "a",
            "selectorSubjectFormatA": {
              "selectLists": ".result > a",
              "preferShorterName": true
            },
            "channelFormatId": "no-channel",
            "selectorChannelFormatNoChannel": {
              "selectEpisodes": ".episodes a",
              "selectEpisodeLinks": "",
              "matchEpisodeSortFromName": "第\\s*(?<ep>.+)\\s*[话集]"
            },
            "matchVideo": {
              "enableNestedUrl": false,
              "matchNestedUrl": "$^",
              "matchVideoUrl": "https?:\\/\\/[^\\s'\\\"<>]+\\.mp4"
            }
          }
        }
      }
    ]
  }
}
